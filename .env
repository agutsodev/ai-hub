AIHUB_ROLE="You are a helpful assistant"
AIHUB_TEMPERATURE=0.5
AIHUB_MAX_TOKENS=4096

AIHUB_SHELL_PREFIX="Generate a shell command compatible with the operating system [os] and that responds to [prompt]. Provide only the commands without explanation unless specifically asked."
AIHUB_CODE_PREFIX="Generate code for the language [lang] and that responds to the [prompt]. Provide only the code without explanation unless specifically asked."

CURL_OPTS="-k -L -s --connect-timeout 5 --max-time 30 --retry 1 --retry-delay 3 --retry-max-time 30"