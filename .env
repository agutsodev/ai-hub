AIHUB_ROLE="You are a helpful assistant"
AIHUB_TEMPERATURE=0.3
AIHUB_MAX_TOKENS=2000

AIHUB_SHELL_PREFIX="Generate a shell command compatible with the operating system [os] and that responds to [prompt]. Add a brief explanation of the generated command."
AIHUB_CODE_PREFIX="Generate code for the language [lang] and that responds to the [prompt]. Add a brief explanation of the generated code."

CURL_OPTS="-k -L -s --connect-timeout 5 --max-time 30 --retry 1 --retry-delay 3 --retry-max-time 30"